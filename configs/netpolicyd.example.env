# netpolicyd environment example
# Copy to /etc/netpolicyd/netpolicyd.env and adjust.

# HTTP listen address (default loopback — put behind a tunnel or firewall for remote)
NETPOLICYD_LISTEN=127.0.0.1:51910

# Bearer token for /v1/* (required in production)
NETPOLICYD_TOKEN=change-me

# Force mock apply (plan only, never exec ip/nft/tc)
# NETPOLICYD_MOCK=1
